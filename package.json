{
  "name": "arte-publica-permanente",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start -c --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start -c --web",
    "test": "jest --watchAll",
    "lint": "eslint . && node --stack-size=4000 ./node_modules/typescript/bin/tsc --noemit",
    "lint:fix": "eslint . --fix",
    "build:web": "expo export -p web --output-dir web-build",
    "build:android": "eas build --profile production --platform android",
    "build:dev-android": "eas build --profile development --platform android",
    "build:dev-ios": "eas build --profile development --platform ios",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@formidable-webview/webshell": "^2.6.0",
    "@googlemaps/react-wrapper": "^1.2.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "date-fns": "^4.1.0",
    "expo": "^56.0.8",
    "expo-blur": "~56.0.3",
    "expo-constants": "~56.0.16",
    "expo-dev-client": "~56.0.18",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-linking": "~56.0.13",
    "expo-router": "~56.2.8",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.5",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~56.0.17",
    "expo-web-browser": "~56.0.5",
    "highcharts": "^12.3.0",
    "highcharts-react-official": "^3.2.2",
    "react": "19.2.3",
    "react-compiler-runtime": "^1.0.0",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-dropdown-picker": "^5.4.6",
    "react-native-easy-grid": "^0.2.2",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-maps": "1.27.2",
    "react-native-pager-view": "8.0.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-tab-view": "^4.1.2",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.8.3",
    "sharp": "^0.34.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@expo/ngrok": "^4.1.3",
    "@types/google.maps": "^3.58.1",
    "@types/highcharts": "^7.0.0",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.10",
    "@types/react-test-renderer": "^19.1.0",
    "eas-cli": "^16.17.3",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "expo-build-properties": "~56.0.16",
    "jest": "~29.7.0",
    "jest-expo": "~56.0.4",
    "patch-package": "^8.0.0",
    "react-test-renderer": "^19.0.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "private": true
