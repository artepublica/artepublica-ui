{
  "name": "arte-publica-permanente",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start -c --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start -c --web",
    "test": "jest --watchAll",
    "lint": "eslint . && node --stack-size=4000 ./node_modules/typescript/bin/tsc --noemit",
    "lint:fix": "eslint . --fix",
    "build:web": "expo export -p web --output-dir web-build",
    "build:android": "eas build --profile production --platform android",
    "build:dev-android": "eas build --profile development --platform android",
    "build:dev-ios": "eas build --profile development --platform ios",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@formidable-webview/webshell": "^2.6.0",
    "@googlemaps/react-wrapper": "^1.2.0",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/drawer": "^7.3.9",
    "@react-navigation/material-top-tabs": "^7.3.4",
    "@react-navigation/native": "^7.1.6",
    "@react-navigation/stack": "^7.4.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "date-fns": "^4.1.0",
    "expo": "^54.0.0",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.24",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.18",
    "expo-web-browser": "~15.0.11",
    "highcharts": "^12.3.0",
    "highcharts-react-official": "^3.2.2",
    "react": "19.1.0",
    "react-compiler-runtime": "^1.0.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-dropdown-picker": "^5.4.6",
    "react-native-easy-grid": "^0.2.2",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-pager-view": "6.9.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-tab-view": "^4.1.2",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "sharp": "^0.34.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@expo/ngrok": "^4.1.3",
    "@types/google.maps": "^3.58.1",
    "@types/highcharts": "^7.0.0",
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.10",
    "@types/react-test-renderer": "^19.1.0",
    "eas-cli": "^16.17.3",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "expo-build-properties": "~1.0.10",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.17",
    "patch-package": "^8.0.0",
    "react-test-renderer": "19.0.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.60.1"
  },
  "private": true
}
